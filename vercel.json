{
  "buildCommand": null,
  "outputDirectory": "public",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/share", "destination": "/api/share" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
